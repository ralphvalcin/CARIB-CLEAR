# CARIB-CLEAR Configuration
# Copy this file to .env and fill in your values

# ── Stellar ──────────────────────────────────────────────────────────
# Stellar Horizon URL (testnet or mainnet)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Stellar network passphrase
STELLAR_NETWORK=Test SDF Network ; September 2015
# Hub account secret key for settlement operations
STELLAR_HUB_SECRET=
# USDC issuer public key (testnet)
STELLAR_USDC_ISSUER=GCO4O4WT6ZJV7MXXSQPH4INW54XP2LRWPQBMHF4JS6BHNVW3FPUYO6AG

# ── API Server ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Demo Mode ────────────────────────────────────────────────────────
# Set to "live" to use Stellar testnet for settlement (requires secrets/)
# CARIB_CLEAR_MODE=mock

# ── Stellar Integration Tests ────────────────────────────────────────
# Set to 1 to run integration tests against live Stellar testnet
STELLAR_INTEGRATION_TEST=0
